{
  "name": "@raybird.chen/memoria",
  "version": "1.12.0",
  "type": "module",
  "description": "Cross-session, traceable, self-hostable persistent memory for AI agents — SQLite-backed CLI + HTTP API + Node SDK.",
  "keywords": [
    "memory",
    "ai",
    "agent",
    "llm",
    "sqlite",
    "cli",
    "persistent-memory",
    "rag",
    "wiki"
  ],
  "homepage": "https://github.com/raybird/Memoria",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raybird/Memoria.git"
  },
  "bugs": {
    "url": "https://github.com/raybird/Memoria/issues"
  },
  "license": "MIT",
  "author": "raybird",
  "bin": {
    "memoria": "dist/cli.mjs"
  },
  "files": [
    "dist/cli.mjs",
    "skills/memoria-memory-sync/",
    "examples/session.sample.json",
    "README.md",
    "README.zh-TW.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "memoria": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "build": "node scripts/build.mjs",
    "memoria:dist": "node dist/cli.mjs",
    "release:docs-check": "node scripts/check-release-doc-sync.mjs",
    "release:package": "bash scripts/package-release-artifacts.sh",
    "release:bump": "node scripts/bump-version.mjs",
    "prepublishOnly": "pnpm run check && pnpm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^14.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
